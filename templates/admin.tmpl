{{template "top" .}}
<title>Admin Dashboard - Joe's Pizza</title>
<style>
    .card-hover {
        transition: all 0.3s ease;
    }
    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px -5px rgba(220, 38, 38, 0.2), 0 8px 10px -6px rgba(220, 38, 38, 0.1);
    }
    
    /* Custom Scrollbar for the table */
    .custom-scrollbar::-webkit-scrollbar {
        height: 8px;
        width: 8px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1; 
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #fca5a5; 
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #ef4444; 
    }
</style>
</head>

<body class="bg-red-50 min-h-screen font-sans text-gray-800 antialiased selection:bg-red-200">

<!-- Header -->
<header class="bg-red-700 text-white shadow-md sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 py-4 flex flex-col sm:flex-row items-center justify-between gap-4">
        <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
            <svg class="w-8 h-8 text-yellow-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2c-5.5 0-10 4.5-10 10s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm1 14.5c-.8 0-1.5-.7-1.5-1.5s.7-1.5 1.5-1.5 1.5.7 1.5 1.5-.7 1.5-1.5 1.5zm-3-5c-.8 0-1.5-.7-1.5-1.5S9.2 8.5 10 8.5s1.5.7 1.5 1.5-.7 1.5-1.5 1.5zm5-2c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1z"/>
            </svg>
            <h1 class="text-2xl font-bold tracking-tight">Joe's Pizza Dashboard</h1>
        </a>
        
        <div class="flex items-center gap-4 bg-red-800 px-2 py-1.5 md:px-4 md:py-2 rounded-2xl shadow-inner border border-red-600 w-full sm:w-auto justify-between sm:justify-end">
            <div class="flex items-center gap-2">
                <div class="w-8 h-8 bg-red-600 rounded-full flex items-center justify-center font-bold text-white border-2 border-red-400">
                    {{printf "%.1s" .Username}}
                </div>
                <span class="text-white font-medium text-sm hidden md:block">Welcome, <span class="font-bold">{{.Username}}</span></span>
            </div>
            <div class="w-[1px] h-6 bg-red-600 mx-2 hidden md:block"></div>
            <form action="/logout" method="POST" class="m-0">
                <button type="submit"
                    class="px-4 py-1.5 bg-red-600 text-white text-sm font-bold rounded-xl hover:bg-red-500 active:scale-95 transition-all shadow-sm flex items-center gap-2">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                    Logout
                </button>
            </form>
        </div>
    </div>
</header>

<main class="w-full max-w-7xl mx-auto p-4 md:p-8">
    <div class="bg-white rounded-3xl shadow-xl border border-gray-100 relative overflow-hidden flex flex-col h-[calc(100vh-140px)] min-h-[600px]">
        
        <!-- Top decorative border -->
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-red-500 to-red-700 z-10"></div>
        
        <div class="p-6 md:p-8 flex-shrink-0 border-b border-gray-100 bg-gray-50/50 mt-2">
            <div class="flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
                <div class="flex items-center gap-3">
                    <div class="p-2.5 bg-red-100 rounded-xl text-red-700 shadow-sm border border-red-200">
                        <svg class="w-7 h-7" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-3 tracking-tight">
                            Active Orders
                            <span id="newOrderBadge" class="hidden bg-red-600 text-white text-[10px] uppercase tracking-wider font-extrabold px-2.5 py-1 rounded-full shadow-sm"></span>
                        </h2>
                        <span id="lastFetched" class="text-xs font-semibold text-gray-500 uppercase tracking-widest mt-1 block"></span>
                    </div>
                </div>
                
                <button onclick="location.reload()"
                    class="flex items-center gap-2 px-4 py-2 text-sm font-bold text-gray-700 bg-white border border-gray-200 rounded-xl hover:bg-gray-50 hover:text-red-600 hover:border-red-200 active:scale-95 transition-all shadow-sm group">
                    <svg class="w-4 h-4 group-hover:rotate-180 transition-transform duration-500 text-red-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                    </svg>
                    Refresh
                </button>
            </div>
        </div>
        
        <div class="flex-1 w-full overflow-auto custom-scrollbar bg-white">
            <table class="w-full min-w-[1000px] text-left border-collapse">
                <thead class="sticky top-0 bg-gray-50/95 backdrop-blur z-10 shadow-sm outline outline-1 outline-gray-200">
                    <tr>
                        <th class="px-6 py-4 text-xs font-black text-gray-500 uppercase tracking-widest whitespace-nowrap">Order ID</th>
                        <th class="px-6 py-4 text-xs font-black text-gray-500 uppercase tracking-widest whitespace-nowrap">Status</th>
                        <th class="px-6 py-4 text-xs font-black text-gray-500 uppercase tracking-widest whitespace-nowrap">Customer Info</th>
                        <th class="px-6 py-4 text-xs font-black text-gray-500 uppercase tracking-widest">Pizzas Ordered</th>
                        <th class="px-6 py-4 text-xs font-black text-gray-500 uppercase tracking-widest whitespace-nowrap text-right">Actions</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                    {{range .Orders}}
                    <tr class="hover:bg-red-50/50 transition-colors group">
                        <td class="px-6 py-5 whitespace-nowrap align-top">
                            <a href="/customer/{{.ID}}" title="View Tracking Page"
                                class="inline-flex items-center gap-2 px-3 py-1.5 bg-red-50 text-red-700 font-bold text-sm rounded-lg border border-red-100 hover:bg-red-600 hover:text-white hover:border-red-600 transition-all shadow-sm">
                                #{{.ID}}
                                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
                            </a>
                        </td>
                        <td class="px-6 py-5 whitespace-nowrap align-top">
                            <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full text-xs font-bold bg-white border border-gray-200 text-gray-700 shadow-sm">
                                <span class="w-2 h-2 rounded-full {{if eq .Status "Order Placed"}}bg-blue-500{{else if eq .Status "Preparing"}}bg-yellow-500{{else if eq .Status "Baking"}}bg-orange-500{{else if eq .Status "Out for Delivery"}}bg-purple-500{{else if eq .Status "Delivered"}}bg-emerald-500{{else}}bg-gray-500{{end}}"></span>
                                {{.Status}}
                            </span>
                        </td>
                        <td class="px-6 py-5 align-top max-w-[250px]">
                            <div class="flex flex-col gap-1">
                                <span class="text-sm font-bold text-gray-900 truncate">{{.CustomerName}}</span>
                                <span class="text-xs font-semibold text-gray-500 flex items-center gap-1"><svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>{{.Phone}}</span>
                                <span class="text-xs text-gray-600 line-clamp-2 mt-1 leading-snug">{{.Address}}</span>
                            </div>
                        </td>
                        <td class="px-6 py-5 align-top">
                            <div class="flex flex-col gap-2">
                                {{range $index, $pizza := .Items}}
                                <div class="bg-gray-50 border border-gray-100 rounded-lg p-2.5 text-xs flex gap-3 relative overflow-hidden group/pizza hover:border-red-200 transition-colors">
                                    <div class="absolute left-0 top-0 w-1 h-full bg-red-200 group-hover/pizza:bg-red-400 transition-colors"></div>
                                    <span class="font-black text-red-800 bg-red-100 rounded px-1.5 py-0.5 h-fit shadow-sm">#{{add $index 1}}</span>
                                    <div class="flex-1 flex flex-col gap-0.5">
                                        <span class="font-bold text-gray-800">{{$pizza.PizzaSize}} {{$pizza.PizzaType}}</span>
                                        <span class="text-gray-500 font-medium">{{$pizza.PizzaCrust}}{{if $pizza.AddOns}} • +{{$pizza.AddOns}}{{end}}</span>
                                        {{if $pizza.Instructions}}
                                        <span class="mt-1 text-gray-600 italic bg-yellow-50 px-2 py-1 rounded border border-yellow-100">"{{$pizza.Instructions}}"</span>
                                        {{end}}
                                    </div>
                                </div>
                                {{end}}
                            </div>
                        </td>
                        <td class="px-6 py-5 whitespace-nowrap text-right align-top">
                            <div class="flex flex-col gap-2 items-end">
                                <form action="/admin/order/{{.ID}}/update" method="POST" class="w-full max-w-[160px]">
                                    <select name="status"
                                        class="w-full px-3 py-2 text-xs font-bold text-gray-700 bg-white border border-gray-200 rounded-lg focus:outline-none focus:ring-2 focus:ring-red-500 focus:border-transparent transition-all cursor-pointer shadow-sm hover:border-gray-300"
                                        onchange="this.form.submit()">
                                        {{$currentStatus := .Status}}
                                        {{range $.Statuses}}
                                        <option value="{{.}}" {{if eq . $currentStatus}}selected{{end}}>
                                            Update: {{.}}
                                        </option>
                                        {{end}}
                                    </select>
                                </form>
                                <form action="/admin/order/{{.ID}}/delete" method="POST">
                                    <button type="submit"
                                        class="inline-flex items-center gap-1 px-3 py-1.5 text-xs font-bold text-red-600 bg-red-50 border border-red-100 rounded-lg hover:bg-red-600 hover:text-white active:scale-95 focus:outline-none focus:ring-2 focus:ring-red-400 transition-all shadow-sm group/btn"
                                        onclick="return confirm('WARNING: Are you sure you want to completely delete order #{{.ID}}? This action cannot be undone.')">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                        </svg>
                                        Delete
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                    {{else}}
                    <tr>
                        <td colspan="5" class="px-6 py-20 text-center text-gray-500">
                            <div class="flex flex-col items-center justify-center gap-3">
                                <div class="p-4 bg-gray-50 rounded-full text-gray-400">
                                    <svg class="w-12 h-12" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/></svg>
                                </div>
                                <h3 class="text-lg font-bold text-gray-700">No active orders found</h3>
                                <p class="text-sm">Waiting for customers to place new orders...</p>
                            </div>
                        </td>
                    </tr>
                    {{end}}
                </tbody>
            </table>
        </div>
    </div>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const updateTime = () => {
            const now = new Date();
            const timeOpts = { hour: '2-digit', minute: '2-digit', second: '2-digit' };
            return `Last Sync: ${now.toLocaleTimeString(undefined, timeOpts)}`;
        };
        const lastFetched = document.getElementById('lastFetched');
        const newOrdersBadge = document.getElementById('newOrderBadge');

        lastFetched.textContent = updateTime();

        let newOrdersCount = 0;
        const eventSrc = new EventSource("/admin/notifications");
        eventSrc.onmessage = e => {
            newOrdersCount++;
            newOrdersBadge.textContent = `${newOrdersCount} New`;
            newOrdersBadge.classList.replace('hidden', 'inline-flex');
            newOrdersBadge.classList.add('animate-bounce');
            lastFetched.textContent = updateTime();
        };
        eventSrc.onerror = err => console.error("EventSource failed: ", err);
    });
</script>

{{template "bottom" .}}