{{template "top" .}}
<title>New Pizza Order - Joe's Pizza</title>
<style>
    .card-hover {
        transition: all 0.3s ease;
    }

    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px -5px rgba(220, 38, 38, 0.2), 0 8px 10px -6px rgba(220, 38, 38, 0.1);
    }

    /* Custom input styling for aesthetics */
    .input-elegant {
        @apply w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-gray-50 hover:bg-white;
    }
</style>
</head>

<body class="bg-red-50 min-h-screen font-sans text-gray-800 antialiased selection:bg-red-200">

    <!-- Header -->
    <header class="bg-red-700 text-white shadow-md sticky top-0 z-50">
        <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
            <a href="/" class="flex items-center gap-3 hover:opacity-90 transition-opacity">
                <svg class="w-8 h-8 text-yellow-300" fill="currentColor" viewBox="0 0 24 24">
                    <path
                        d="M12 2c-5.5 0-10 4.5-10 10s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm1 14.5c-.8 0-1.5-.7-1.5-1.5s.7-1.5 1.5-1.5 1.5.7 1.5 1.5-.7 1.5-1.5 1.5zm-3-5c-.8 0-1.5-.7-1.5-1.5S9.2 8.5 10 8.5s1.5.7 1.5 1.5-.7 1.5-1.5 1.5zm5-2c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1z" />
                </svg>
                <h1 class="text-2xl font-bold tracking-tight">Joe's Pizza</h1>
            </a>
        </div>
    </header>

    <main class="flex flex-col items-center p-4 md:p-8 w-full max-w-4xl mx-auto">
        <div
            class="w-full bg-white rounded-3xl shadow-xl p-6 md:p-10 border border-gray-100 card-hover relative overflow-hidden">
            <!-- Top decorative border -->
            <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-red-500 to-red-700"></div>

            <div class="text-center mb-10 mt-2">
                <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 tracking-tight mb-3">Place Your Order</h1>
                <p class="text-gray-500 font-medium">Build the perfect pizza for delivery.</p>
            </div>

            <form action="/new-order" method="POST" class="space-y-10">

                <!-- Customer Information Section -->
                <section>
                    <div class="flex items-center gap-3 mb-6">
                        <div class="p-2 bg-red-50 rounded-lg text-red-600">
                            <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round"
                                    d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <h2 class="text-xl font-bold text-gray-800">Who is it for?</h2>
                    </div>

                    <div
                        class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-gray-50/50 p-6 border border-gray-100 rounded-2xl">
                        <div class="md:col-span-2 lg:col-span-1">
                            <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide"
                                for="name">Full Name</label>
                            <input type="text" id="name" name="name" required minlength="2" maxlength="100"
                                placeholder="John Doe"
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-white hover:bg-gray-50 shadow-sm">
                        </div>
                        <div class="md:col-span-2 lg:col-span-1">
                            <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide"
                                for="phone">Phone Number</label>
                            <input type="tel" id="phone" name="phone" required minlength="10" maxlength="20"
                                placeholder="+628123456789"
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-white hover:bg-gray-50 shadow-sm">
                        </div>
                        <div class="md:col-span-2">
                            <label class="block text-gray-700 text-sm font-bold mb-2 uppercase tracking-wide"
                                for="address">Delivery Address</label>
                            <input type="text" id="address" name="address" required minlength="5" maxlength="200"
                                placeholder="123 Pizza Street, Foodville"
                                class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-white hover:bg-gray-50 shadow-sm">
                        </div>
                    </div>
                </section>

                <hr class="border-gray-100">

                <!-- Pizzas Section -->
                <section>
                    <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-6">
                        <div class="flex items-center gap-3">
                            <div class="p-2 bg-red-50 rounded-lg text-red-600">
                                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2"
                                    viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round"
                                        d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z" />
                                </svg>
                            </div>
                            <h2 class="text-xl font-bold text-gray-800">Your Pizzas</h2>
                        </div>
                        <button type="button" onclick="addPizza()"
                            class="flex items-center gap-2 px-5 py-2.5 text-sm font-bold text-red-700 bg-red-50 border border-red-200 rounded-xl hover:bg-red-100 hover:border-red-300 active:scale-95 transition-all shadow-sm">
                            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                    d="M12 4v16m8-8H4" />
                            </svg>
                            Add Another Pizza
                        </button>
                    </div>

                    <div id="pizzas" class="space-y-6">
                        <!-- Pizzas will be injected here -->
                    </div>
                </section>

                <!-- Submit -->
                <div class="pt-4">
                    <button type="submit"
                        class="w-full bg-red-600 text-white font-bold text-lg py-4 px-6 rounded-2xl hover:bg-red-700 active:scale-[0.98] transition-all shadow-lg shadow-red-600/30 flex justify-center items-center gap-2 group">
                        <span>Submit Complete Order</span>
                        <svg class="w-5 h-5 group-hover:translate-x-1 transition-transform" fill="none"
                            stroke="currentColor" viewBox="0 0 24 24">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                d="M14 5l7 7m0 0l-7 7m7-7H3" />
                        </svg>
                    </button>
                </div>

            </form>
        </div>
    </main>

    <template id="pizzaTemplate">
        <div
            class="pizza-item relative bg-white border border-gray-200 rounded-2xl p-6 shadow-sm hover:border-red-200 transition-colors duration-300 group overflow-hidden">
            <!-- Colored left trim indicator -->
            <div
                class="absolute top-0 left-0 w-1 h-full bg-red-400 opacity-0 group-hover:opacity-100 transition-opacity">
            </div>

            <div class="flex justify-between items-center mb-6 border-b border-gray-100 pb-4">
                <h3 class="text-lg font-bold text-gray-800 flex items-center gap-2">
                    Pizza <span class="bg-red-100 text-red-700 px-2 py-0.5 rounded text-sm pizza-number"></span>
                </h3>
                <button type="button" onclick="removePizza(this)"
                    class="remove-btn text-gray-400 border border-gray-200 px-3 py-1.5 rounded-lg hover:text-red-600 hover:bg-red-50 hover:border-red-200 text-sm font-semibold transition-all">
                    Remove
                </button>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label class="block text-gray-600 text-xs font-bold mb-2 uppercase tracking-wide">Size</label>
                    <select name="sizes" required
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-gray-50 hover:bg-white text-gray-800 font-medium cursor-pointer shadow-sm">
                        {{range $.PizzaSizes}}
                        <option value="{{.}}">{{.}}</option>
                        {{end}}
                    </select>
                </div>
                <div>
                    <label class="block text-gray-600 text-xs font-bold mb-2 uppercase tracking-wide">Type /
                        Flavor</label>
                    <select name="types" required
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-gray-50 hover:bg-white text-gray-800 font-medium cursor-pointer shadow-sm">
                        {{range $.PizzaTypes}}
                        <option value="{{.}}">{{.}}</option>
                        {{end}}
                    </select>
                </div>
                <div>
                    <label class="block text-gray-600 text-xs font-bold mb-2 uppercase tracking-wide">Crust</label>
                    <select name="crusts" required
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-gray-50 hover:bg-white text-gray-800 font-medium cursor-pointer shadow-sm">
                        {{range $.PizzaCrusts}}
                        <option value="{{.}}">{{.}}</option>
                        {{end}}
                    </select>
                </div>
                <div>
                    <label class="block text-gray-600 text-xs font-bold mb-2 uppercase tracking-wide">Extra
                        Add-Ons</label>
                    <select name="addons" required
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-gray-50 hover:bg-white text-gray-800 font-medium cursor-pointer shadow-sm">
                        {{range $.PizzaAddOns}}
                        <option value="{{.}}">{{.}}</option>
                        {{end}}
                    </select>
                </div>
                <div class="md:col-span-2">
                    <label class="block text-gray-600 text-xs font-bold mb-2 uppercase tracking-wide">Special
                        Instructions (Optional)</label>
                    <textarea maxlength="200" name="instructions" rows="2"
                        placeholder="E.g., Extra crispy, cut into squares..."
                        class="w-full px-4 py-3 border border-gray-200 rounded-xl focus:outline-none focus:ring-2 focus:ring-red-600 focus:border-transparent transition-all bg-gray-50 hover:bg-white resize-none shadow-sm"></textarea>
                </div>
            </div>
        </div>
    </template>

    <script>
        let pizzaCount = 0;

        function addPizza() {
            const clone = document.getElementById('pizzaTemplate').content.cloneNode(true);
            pizzaCount++;
            clone.querySelector('.pizza-number').textContent = "#" + pizzaCount;

            // Hide remove button if it's the only pizza
            const item = clone.querySelector('.pizza-item');
            document.getElementById('pizzas').appendChild(clone);
            updateRemoveButtons();
        }

        function removePizza(btn) {
            btn.closest('.pizza-item').remove();

            // Renumber remaining pizzas
            const items = document.querySelectorAll('.pizza-item');
            items.forEach((item, index) => {
                item.querySelector('.pizza-number').textContent = "#" + (index + 1);
            });

            pizzaCount = items.length;
            updateRemoveButtons();
        }

        function updateRemoveButtons() {
            // Prevent user from removing the last pizza
            const items = document.querySelectorAll('.pizza-item');
            items.forEach(item => {
                const btn = item.querySelector('.remove-btn');
                if (items.length === 1) {
                    btn.style.display = 'none';
                } else {
                    btn.style.display = 'block';
                }
            });
        }

        // Add one pizza by default when page loads
        document.addEventListener("DOMContentLoaded", () => {
            addPizza();
        });
    </script>

    {{template "bottom" .}}