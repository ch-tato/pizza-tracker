{{template "top" .}}
<title>Track Order #{{.Order.ID}}</title>
<style>
    /* Custom playful font if needed, defaulting to sans */
    @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;600;700;800&display=swap');

    body {
        font-family: 'Nunito', sans-serif;
    }

    .status-dot {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }

    .status-line {
        transition: height 0.5s ease;
    }

    .pulse-ring {
        animation: pulseFade 2s infinite;
    }

    @keyframes pulseFade {
        0% {
            transform: scale(0.8);
            opacity: 0.8;
        }

        70% {
            transform: scale(2);
            opacity: 0;
        }

        100% {
            transform: scale(2);
            opacity: 0;
        }
    }
</style>
</head>

<body class="bg-[#FDFBF7] min-h-screen text-gray-800 pb-10">

    <!-- Top Red Banner -->
    <div class="bg-[#E53935] text-white rounded-b-[40px] pt-12 pb-24 px-6 shadow-lg relative z-0">
        <div class="flex justify-between items-center mb-6">
            <!-- Back Button / Menu -->
            <button class="bg-white/20 p-3 rounded-full hover:bg-white/30 transition backdrop-blur-sm">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-white" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 19l-7-7 7-7" />
                </svg>
            </button>
            <h1 class="text-xl font-bold tracking-wide">Track Order</h1>
            <!-- Avatar / Profile -->
            <div class="bg-white/20 p-1 rounded-full backdrop-blur-sm flex items-center justify-center">
                <img src="https://ui-avatars.com/api/?name={{.Order.CustomerName}}&background=fff&color=E53935&bold=true"
                    alt="Profile" class="h-10 w-10 rounded-full border-2 border-white shadow-sm">
            </div>
        </div>

        <div class="text-center">
            <p class="text-red-100 text-sm font-semibold uppercase tracking-wider mb-1">Order ID</p>
            <p
                class="text-3xl font-extrabold tracking-widest bg-clip-text text-transparent bg-gradient-to-r from-white to-red-50">
                #{{.Order.ID}}</p>
        </div>
    </div>

    <div class="px-6 -mt-16 relative z-10 max-w-md mx-auto space-y-6">

        <!-- Estimated Time Card -->
        <div
            class="bg-white rounded-3xl p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100 flex items-center justify-between">
            <div class="flex flex-col">
                <span class="text-gray-400 text-sm font-bold uppercase tracking-wider mb-1">Estimated Delivery</span>
                <span class="text-3xl font-extrabold text-[#E53935]" id="est-time">30 <span
                        class="text-xl text-gray-800">mins</span></span>
            </div>
            <div class="h-16 w-16 bg-red-50 rounded-2xl flex items-center justify-center shadow-inner">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-[#E53935]" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z" />
                </svg>
            </div>
        </div>

        <!-- Tracking Stepper Card -->
        <div class="bg-white rounded-3xl p-6 shadow-[0_8px_30px_rgb(0,0,0,0.04)] border border-gray-100">
            <h2 class="text-lg font-extrabold text-gray-800 mb-6">Order Status</h2>

            <div class="relative px-2">
                <!-- Status List -->
                <div class="space-y-8" id="stepper">
                    {{$status := .Order.Status}}

                    <!-- Render each step -->
                    {{$steps := slice "Order Placed" "Preparing" "Baking" "Out for Delivery" "Delivered"}}

                    <!-- We use JS to dynamically update classes for a seamless experience without complex Go template logic -->
                    <div class="step-item relative flex items-start gap-4" data-step="Order Placed">
                        <div class="relative flex flex-col items-center">
                            <div
                                class="h-5 w-5 rounded-full border-4 border-gray-200 bg-white status-dot z-10 relative">
                            </div>
                            <div class="w-[2px] h-12 bg-gray-100 absolute top-5 status-line"></div>
                        </div>
                        <div class="flex-1 -mt-1">
                            <p class="font-bold text-gray-400 step-title text-lg">Order Placed</p>
                            <p class="text-sm text-gray-400 step-desc hidden mt-1">We've received your order</p>
                        </div>
                    </div>

                    <div class="step-item relative flex items-start gap-4" data-step="Preparing">
                        <div class="relative flex flex-col items-center">
                            <div
                                class="h-5 w-5 rounded-full border-4 border-gray-200 bg-white status-dot z-10 relative">
                            </div>
                            <div class="w-[2px] h-12 bg-gray-100 absolute top-5 status-line"></div>
                        </div>
                        <div class="flex-1 -mt-1">
                            <p class="font-bold text-gray-400 step-title text-lg">Preparing</p>
                            <p class="text-sm text-gray-400 step-desc hidden mt-1">Our chefs are assembling your pizza
                            </p>
                        </div>
                    </div>

                    <div class="step-item relative flex items-start gap-4" data-step="Baking">
                        <div class="relative flex flex-col items-center">
                            <div
                                class="h-5 w-5 rounded-full border-4 border-gray-200 bg-white status-dot z-10 relative">
                            </div>
                            <div class="w-[2px] h-12 bg-gray-100 absolute top-5 status-line"></div>
                        </div>
                        <div class="flex-1 -mt-1">
                            <p class="font-bold text-gray-400 step-title text-lg">Baking</p>
                            <p class="text-sm text-gray-400 step-desc hidden mt-1">In the oven to perfection</p>
                        </div>
                    </div>

                    <div class="step-item relative flex items-start gap-4" data-step="Out for Delivery">
                        <div class="relative flex flex-col items-center">
                            <div
                                class="h-5 w-5 rounded-full border-4 border-gray-200 bg-white status-dot z-10 relative">
                            </div>
                            <div class="w-[2px] h-12 bg-gray-100 absolute top-5 status-line"></div>
                        </div>
                        <div class="flex-1 -mt-1">
                            <p class="font-bold text-gray-400 step-title text-lg">Out for Delivery</p>
                            <p class="text-sm text-gray-400 step-desc hidden mt-1">On the way to your door!</p>
                        </div>
                    </div>

                    <div class="step-item relative flex items-start gap-4" data-step="Delivered">
                        <div class="relative flex flex-col items-center">
                            <div
                                class="h-5 w-5 rounded-full border-4 border-gray-200 bg-white status-dot z-10 relative">
                            </div>
                        </div>
                        <div class="flex-1 -mt-1">
                            <p class="font-bold text-gray-400 step-title text-lg">Delivered</p>
                            <p class="text-sm text-gray-400 step-desc hidden mt-1">Enjoy your pizza!</p>
                        </div>
                    </div>

                </div>
            </div>
        </div>

        <!-- Conditional Driver Card -->
        {{if eq .Order.Status "Out for Delivery"}}
        <div
            class="bg-[#E53935] rounded-3xl p-5 shadow-lg shadow-red-500/30 flex items-center justify-between text-white animate-[fade-in_0.5s_ease-out]">
            <div class="flex items-center gap-4">
                <div class="relative">
                    <img src="https://ui-avatars.com/api/?name=Driver+Dan&background=fff&color=E53935&bold=true"
                        alt="Driver" class="h-14 w-14 rounded-full border-2 border-white shadow-md">
                    <div
                        class="absolute -bottom-1 -right-1 bg-green-400 h-4 w-4 rounded-full border-2 border-[#E53935]">
                    </div>
                </div>
                <div>
                    <p class="text-xs text-red-100 font-bold uppercase tracking-wider mb-1">Your Driver</p>
                    <p class="font-bold text-lg leading-tight">Driver Dan</p>
                    <p class="text-sm text-red-100/80">Ford Transit • AB 123 CD</p>
                </div>
            </div>
            <button
                class="bg-white text-[#E53935] h-12 w-12 rounded-2xl flex items-center justify-center shadow-sm hover:scale-105 transition-transform active:scale-95">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                    stroke="currentColor" stroke-width="2">
                    <path stroke-linecap="round" stroke-linejoin="round"
                        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                </svg>
            </button>
        </div>
        {{end}}

        <!-- Order Items Summary -->
        <h3 class="text-xl font-extrabold text-gray-800 mt-8 mb-4 px-2 tracking-tight">Your Order</h3>
        <div class="space-y-4 mb-10">
            {{range .Order.Items}}
            <div
                class="bg-white rounded-3xl p-5 shadow-[0_4px_20px_rgb(0,0,0,0.03)] border border-gray-100 flex items-center gap-4 hover:shadow-[0_8px_30px_rgb(0,0,0,0.06)] transition-shadow">
                <div class="bg-orange-50 h-[72px] w-[72px] rounded-2xl flex items-center justify-center shrink-0">
                    <span class="text-4xl text-amber-500">🍕</span>
                </div>
                <div class="flex-1">
                    <p class="font-extrabold text-gray-800 text-lg leading-tight">{{.PizzaSize}} {{.PizzaType}}</p>
                    <p class="text-sm text-gray-500 mt-1 font-medium">{{.PizzaCrust}}{{if .AddOns}} • {{.AddOns}}{{end}}
                    </p>
                    {{if .Instructions}}<p
                        class="text-xs text-[#E53935] font-semibold mt-1 bg-red-50 inline-block px-2 py-1 rounded-md">
                        Note: {{.Instructions}}</p>{{end}}
                </div>
            </div>
            {{end}}
        </div>

    </div>

    <!-- Script to Handle Dynamic Stepper Logic -->
    <script>
        document.addEventListener("DOMContentLoaded", () => {
            const currentStatus = "{{.Order.Status}}";
            const sequence = ["Order Placed", "Preparing", "Baking", "Out for Delivery", "Delivered"];
            const currentIndex = sequence.indexOf(currentStatus);

            const steps = document.querySelectorAll('.step-item');

            steps.forEach((step, index) => {
                const stepName = step.getAttribute('data-step');
                const dot = step.querySelector('.status-dot');
                const line = step.querySelector('.status-line');
                const title = step.querySelector('.step-title');
                const desc = step.querySelector('.step-desc');

                if (index < currentIndex) {
                    // Completed Steps
                    dot.classList.remove('border-gray-200', 'bg-white');
                    dot.classList.add('border-[#E53935]', 'bg-[#E53935]');
                    if (title) {
                        title.classList.remove('text-gray-400');
                        title.classList.add('text-gray-800');
                    }
                    if (line) {
                        line.classList.remove('bg-gray-100');
                        line.classList.add('bg-[#E53935]');
                    }
                } else if (index === currentIndex) {
                    // Active Step
                    dot.classList.remove('border-gray-200', 'bg-white');
                    dot.classList.add('border-[#E53935]', 'bg-white');

                    // Add pulse ring effect around active dot
                    const pulse = document.createElement('div');
                    pulse.className = 'absolute inset-0 bg-red-400 rounded-full pulse-ring -z-10';
                    dot.appendChild(pulse);

                    if (title) {
                        title.classList.remove('text-gray-400');
                        title.classList.add('text-[#E53935]');
                        title.parentElement.classList.remove('-mt-1'); // Adjust alignment slightly for active
                    }
                    if (desc) {
                        desc.classList.remove('hidden'); // Show description for active step
                    }
                    if (line) {
                        // Partial fill line for next step if it's not the last step
                        line.style.background = 'linear-gradient(to bottom, #E53935 0%, #f3f4f6 100%)';
                    }
                }
            });

            // Make the estimated time dynamic based on status
            const estTime = document.getElementById('est-time');
            if (currentIndex === 0) estTime.innerHTML = '30 <span class="text-xl text-gray-800">m</span>';
            if (currentIndex === 1) estTime.innerHTML = '20 <span class="text-xl text-gray-800">m</span>';
            if (currentIndex === 2) estTime.innerHTML = '12 <span class="text-xl text-gray-800">m</span>';
            if (currentIndex === 3) estTime.innerHTML = '5 <span class="text-xl text-gray-800">m</span>';
            if (currentIndex === 4) estTime.innerHTML = '0 <span class="text-xl text-gray-800">m</span>';
            if (currentIndex === 4) estTime.parentElement.innerHTML = '<span class="text-green-500 font-extrabold text-2xl">Delivered!</span>';
        });
    </script>

    {{template "bottom" .}}