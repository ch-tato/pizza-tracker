{{template "top" .}}
<title>{{.Title}}</title>
<style>
    @keyframes float {
        0%, 100% { transform: translateY(0) rotate(0deg); }
        50% { transform: translateY(-15px) rotate(3deg); }
    }
    @keyframes spin {
        from { transform: rotate(0deg); }
        to { transform: rotate(360deg); }
    }
    .animate-spin-slow {
        animation: spin 8s linear infinite;
    }
    .animate-float {
        animation: float 4s ease-in-out infinite;
    }
    .progress-transition {
        transition: width 0.8s cubic-bezier(0.4, 0, 0.2, 1), background-color 0.8s ease;
    }
    .step-transition {
        transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .card-hover {
        transition: all 0.3s ease;
    }
    .card-hover:hover {
        transform: translateY(-5px);
        box-shadow: 0 10px 25px -5px rgba(220, 38, 38, 0.2), 0 8px 10px -6px rgba(220, 38, 38, 0.1);
    }
    /* Custom Scrollbar for the pizza items */
    .custom-scrollbar::-webkit-scrollbar {
        width: 6px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
        background: #f1f1f1; 
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
        background: #fca5a5; 
        border-radius: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover {
        background: #ef4444; 
    }
</style>
</head>
<body class="bg-red-50 min-h-screen font-sans text-gray-800 antialiased selection:bg-red-200">

<!-- Header -->
<header class="bg-red-700 text-white shadow-md sticky top-0 z-50">
    <div class="max-w-4xl mx-auto px-4 py-4 flex items-center justify-between">
        <div class="flex items-center gap-3">
            <svg class="w-8 h-8 text-yellow-300" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2c-5.5 0-10 4.5-10 10s4.5 10 10 10 10-4.5 10-10S17.5 2 12 2zm1 14.5c-.8 0-1.5-.7-1.5-1.5s.7-1.5 1.5-1.5 1.5.7 1.5 1.5-.7 1.5-1.5 1.5zm-3-5c-.8 0-1.5-.7-1.5-1.5S9.2 8.5 10 8.5s1.5.7 1.5 1.5-.7 1.5-1.5 1.5zm5-2c-.6 0-1-.4-1-1s.4-1 1-1 1 .4 1 1-.4 1-1 1z"/>
            </svg>
            <h1 class="text-2xl font-bold tracking-tight">Joe's Pizza</h1>
        </div>
        <div class="text-sm font-medium bg-red-800 px-3 py-1 rounded-full shadow-inner border border-red-600">
            Order #{{ .Order.ID }}
        </div>
    </div>
</header>

<main class="flex flex-col items-center p-4 md:p-8 w-full max-w-4xl mx-auto space-y-8">
    
    <!-- Floating Pizza SVG -->
    <div class="mt-4 mb-2">
        <img src="/static/pizza.svg" class="w-48 h-48 animate-float animate-spin-slow drop-shadow-2xl" alt="Delicious Pizza">
    </div>

    <!-- Status Card -->
    <section class="w-full bg-white rounded-3xl shadow-xl p-6 md:p-10 border border-gray-100 card-hover relative overflow-hidden">
        <div class="absolute top-0 left-0 w-full h-2 bg-gradient-to-r from-red-500 to-red-700"></div>
        
        <h2 class="text-2xl md:text-3xl font-extrabold text-gray-900 mb-2 text-center">
            Tracking Your Order
        </h2>
        <p class="text-gray-500 text-center mb-8 font-medium">We're working our magic on your pizza!</p>

        <!-- Progress Stepper -->
        <div class="relative w-full max-w-2xl mx-auto mb-12 mt-6">
            <!-- Background Line -->
            <div class="absolute top-1/2 left-[5%] right-[5%] h-1.5 bg-gray-200 -translate-y-1/2 rounded-full hidden sm:block"></div>
            <!-- Animated Fill Line -->
            <div id="progressLine" class="absolute top-1/2 left-[5%] h-1.5 bg-red-600 -translate-y-1/2 rounded-full progress-transition w-0 hidden sm:block"></div>
            
            <div class="flex flex-col sm:flex-row justify-between relative z-10 gap-6 sm:gap-0">
                {{range $index, $status := .Statuses}}
                <div class="flex flex-row sm:flex-col items-center gap-4 sm:gap-4 group w-full sm:w-1/4">
                    <div id="step-icon-{{add $index 1}}" 
                        class="w-12 h-12 rounded-full flex items-center justify-center bg-white border-4 border-gray-200 text-gray-400 font-bold step-transition shadow-sm group-hover:scale-110 shrink-0">
                        {{add $index 1}}
                    </div>
                    <span id="step-text-{{add $index 1}}" class="text-sm font-bold text-gray-400 step-transition text-left sm:text-center flex-1 sm:flex-none">
                        {{$status}}
                    </span>
                </div>
                {{end}}
            </div>
        </div>
    </section>

    <!-- Details Grid -->
    <div class="w-full grid grid-cols-1 md:grid-cols-2 gap-6 pb-12">
        
        <!-- Customer Info Card -->
        <section class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100 card-hover h-full">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-2 bg-red-50 rounded-lg text-red-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-800">Delivery Details</h3>
            </div>
            <div class="space-y-4">
                <div class="flex flex-col p-3 bg-gray-50 rounded-xl border border-gray-100">
                    <span class="text-xs text-red-600 font-bold uppercase tracking-wider mb-1">Customer Name</span>
                    <span class="text-gray-900 font-medium">{{ .Order.CustomerName }}</span>
                </div>
                <div class="flex flex-col p-3 bg-gray-50 rounded-xl border border-gray-100">
                    <span class="text-xs text-red-600 font-bold uppercase tracking-wider mb-1">Phone Number</span>
                    <span class="text-gray-900 font-medium">{{ .Order.Phone }}</span>
                </div>
                <div class="flex flex-col p-3 bg-gray-50 rounded-xl border border-gray-100">
                    <span class="text-xs text-red-600 font-bold uppercase tracking-wider mb-1">Delivery Address</span>
                    <span class="text-gray-900 font-medium leading-relaxed">{{ .Order.Address }}</span>
                </div>
            </div>
        </section>

        <!-- Order Items Card -->
        <section class="bg-white rounded-2xl shadow-lg p-6 border border-gray-100 card-hover h-full flex flex-col">
            <div class="flex items-center gap-3 mb-6">
                <div class="p-2 bg-red-50 rounded-lg text-red-600">
                    <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M3 3h2l.4 2M7 13h10l4-8H5.4M7 13L5.4 5M7 13l-2.293 2.293c-.63.63-.184 1.707.707 1.707H17m0 0a2 2 0 100 4 2 2 0 000-4zm-8 2a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <h3 class="text-xl font-bold text-gray-800">Your Pizzas</h3>
            </div>
            
            <div class="space-y-4 overflow-y-auto pr-2 custom-scrollbar flex-1 max-h-96">
                {{range $index, $pizza := .Order.Items}}
                <div class="p-4 rounded-xl bg-gray-50 border border-gray-100 hover:bg-red-50 hover:border-red-200 transition-colors duration-200 relative overflow-hidden group">
                    <div class="absolute top-0 left-0 w-1 h-full bg-red-400 opacity-0 group-hover:opacity-100 transition-opacity"></div>
                    
                    <div class="flex justify-between items-start mb-3">
                        <span class="font-bold text-gray-900 text-lg">{{ $pizza.PizzaSize }} {{ $pizza.PizzaType }}</span>
                        <span class="text-xs font-black text-red-700 bg-red-100 px-2.5 py-1 rounded-full shadow-sm">#{{add $index 1}}</span>
                    </div>
                    
                    <div class="space-y-2">
                        <div class="flex gap-2 items-start text-sm">
                            <span class="flex-shrink-0 w-16 font-semibold text-gray-500 uppercase text-xs tracking-wider mt-0.5">Crust:</span> 
                            <span class="text-gray-800 font-medium">{{ $pizza.PizzaCrust }}</span>
                        </div>
                        
                        {{if $pizza.AddOns}}
                        <div class="flex gap-2 items-start text-sm">
                            <span class="flex-shrink-0 w-16 font-semibold text-gray-500 uppercase text-xs tracking-wider mt-0.5">Extras:</span> 
                            <span class="text-gray-800 font-medium">{{ $pizza.AddOns }}</span>
                        </div>
                        {{end}}
                        
                        {{if $pizza.Instructions}}
                        <div class="mt-3 bg-yellow-50 p-3 rounded-lg border border-yellow-100 flex items-start gap-2">
                            <svg class="w-4 h-4 text-yellow-500 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                            <span class="text-sm text-gray-700 italic">"{{$pizza.Instructions}}"</span>
                        </div>
                        {{end}}
                    </div>
                </div>
                {{end}}
            </div>
        </section>

    </div>
</main>

<script type="application/json" id="statuses-data">
    {{ json .Statuses }}
</script>

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const statuses = JSON.parse(document.getElementById('statuses-data').textContent);
        
        function updateStatusBar(currentStatus) {
            const currentIndex = statuses.indexOf(currentStatus);
            let activeColorClass = "bg-red-600";
            let activeBorderClass = "border-red-200";
            
            statuses.forEach((status, index) => {
                const stepIcon = document.getElementById(`step-icon-${index + 1}`);
                const stepText = document.getElementById(`step-text-${index + 1}`);
                
                // Completed Steps
                if (index < currentIndex) {
                    stepIcon.className = `w-12 h-12 rounded-full flex items-center justify-center ${activeColorClass} border-4 ${activeBorderClass} text-white font-bold step-transition shadow-md group-hover:scale-110 shrink-0`;
                    stepIcon.innerHTML = `<svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7"/></svg>`;
                    stepText.className = "text-sm font-bold text-red-700 step-transition text-left sm:text-center shrink flex-1 sm:flex-none";
                } 
                // Current Step
                else if (index === currentIndex) {
                    stepIcon.className = `w-12 h-12 rounded-full flex items-center justify-center bg-white border-4 border-red-600 text-red-600 font-bold step-transition shadow-lg scale-110 shrink-0 ring-4 ring-red-100 ring-offset-2`;
                    stepIcon.innerHTML = `${index + 1}`;
                    stepText.className = "text-sm font-extrabold text-red-700 step-transition text-left sm:text-center scale-105 origin-left sm:origin-center shrink flex-1 sm:flex-none";
                } 
                // Future Steps
                else {
                    stepIcon.className = "w-12 h-12 rounded-full flex items-center justify-center bg-white border-4 border-gray-200 text-gray-400 font-bold step-transition group-hover:scale-110 group-hover:border-gray-300 group-hover:text-gray-500 shrink-0";
                    stepIcon.innerHTML = `${index + 1}`;
                    stepText.className = "text-sm font-bold text-gray-400 step-transition text-left sm:text-center opacity-70 shrink flex-1 sm:flex-none";
                }
            });

            // Update line width for desktop
            const progressLine = document.getElementById("progressLine");
            if (progressLine && statuses.length > 1) {
                // Determine percentage. 
                // For 4 steps: 0, 1, 2, 3. The length between centers is roughly (index / (length - 1))
                // With 4 items, 3 gaps. But we started the line at left-[5%] right-[5%] (it's 90% wide).
                const percentage = (currentIndex / (statuses.length - 1)) * 90;
                progressLine.style.width = `${percentage}%`;
            }
        }

        updateStatusBar("{{.Order.Status}}");

        // SSE Setup
        const eventSrc = new EventSource(`/notifications?orderId={{.Order.ID}}`);
        eventSrc.onmessage = () => {
            // Apply a fade-out effect
            document.body.style.opacity = '0.5';
            document.body.style.transition = 'opacity 0.4s ease';
            document.body.style.transform = 'scale(0.99)';
            
            // Reload cleanly after animation
            setTimeout(() => location.reload(), 400);
        };
        eventSrc.onerror = err => console.error("EventSource failed: ", err);
    });
</script>

{{template "bottom" .}}